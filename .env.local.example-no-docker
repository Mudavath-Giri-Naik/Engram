# =============================================================================
# Engram LOCAL MODE — run the full API + dashboard with NO Docker, NO Postgres,
# NO Qdrant server, and NO torch. Copy this over .env.local to use it:
#
#   Windows PowerShell:  Copy-Item .env.local.example-no-docker .env.local
#   macOS/Linux:         cp .env.local.example-no-docker .env.local
#
# Then:
#   alembic upgrade head
#   python -m engram.cli bootstrap
#   python -m engram.cli serve        # http://localhost:8000/docs
#   python -m engram.cli dashboard    # http://localhost:8501  (second terminal)
# =============================================================================

APP_ENV=dev
API_HOST=127.0.0.1
API_PORT=8000

# SQLite file instead of Postgres (no server needed)
DATABASE_URL=sqlite+pysqlite:///./engram.db

# Embedded, on-disk Qdrant instead of a Qdrant server (no Docker needed).
# "local" -> stored under ./.engram/qdrant
QDRANT_URL=local
QDRANT_API_KEY=
QDRANT_COLLECTION=engram_incidents

# Built-in deterministic embedder (no sentence-transformers / torch required).
# Swap to BAAI/bge-small-en-v1.5 once you have torch installed for better quality.
EMBEDDING_MODEL=hashing
EMBEDDING_DIM=384

# Reasoning LLM — fill these to enable comparative reasoning on /v1/query.
# Leave as-is and retrieval still works; reasoning returns a clear "configure key" note.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-latest
LLM_API_KEY=REPLACE_WITH_YOUR_LLM_API_KEY

# Tenant bootstrap (any strings)
ENGRAM_BOOTSTRAP_API_KEY=local-dev-key
ENGRAM_BOOTSTRAP_NETWORK_ID=acme-core-network

DEVICE_SSH_USERNAME=admin
DEVICE_SSH_PASSWORD=admin

RETRIEVAL_W_VECTOR=0.6
RETRIEVAL_W_STRUCTURED=0.4
