# =============================================================================
# Engram DOCKER mode — real Postgres + real Qdrant running in containers.
# Copy this over .env.local to use it:
#
#   Windows PowerShell:  Copy-Item .env.local.example-docker .env.local
#
# Then (from the Engram folder, with Docker Desktop running):
#   docker compose up -d
#   alembic upgrade head
#   python -m engram.cli bootstrap
#   python -m engram.cli serve        # http://localhost:8000/docs
#   python -m engram.cli dashboard    # http://localhost:8501  (second terminal)
# =============================================================================

APP_ENV=dev
API_HOST=127.0.0.1
API_PORT=8000

# Real Postgres (matches docker-compose.yml credentials)
DATABASE_URL=postgresql+psycopg://engram:engram@localhost:5432/engram

# Real Qdrant server (the container started by docker compose)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=engram_incidents

# Embedder: keep "hashing" if you're on Python 3.14 (torch has no wheels there yet).
# Switch to the real model on Python 3.11/3.12 after `pip install sentence-transformers`.
EMBEDDING_MODEL=hashing
EMBEDDING_DIM=384

# Reasoning LLM — Google Gemini (AI Studio). Get a key: https://aistudio.google.com/apikey
# gemini-2.5-flash is a cheaper/faster alternative to gemini-2.5-pro.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-pro
LLM_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Tenant bootstrap (any strings)
ENGRAM_BOOTSTRAP_API_KEY=local-dev-key
ENGRAM_BOOTSTRAP_NETWORK_ID=acme-core-network

DEVICE_SSH_USERNAME=admin
DEVICE_SSH_PASSWORD=admin

RETRIEVAL_W_VECTOR=0.6
RETRIEVAL_W_STRUCTURED=0.4
