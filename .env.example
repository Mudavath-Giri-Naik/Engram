# =============================================================================
# Engram configuration — copy to .env.local and fill in the placeholders.
#
#   cp .env.example .env.local
#
# .env.local is gitignored and must NEVER be committed. Only the reasoning LLM
# requires a paid key; embeddings run locally via sentence-transformers.
# =============================================================================

# ---- app --------------------------------------------------------------------
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

# ---- structured store (PostgreSQL 16) ---------------------------------------
# Matches the credentials in docker-compose.yml. Change USER/PASSWORD if you
# edit the compose file. psycopg v3 driver ("+psycopg") is required.
DATABASE_URL=postgresql+psycopg://engram:engram@localhost:5432/engram

# ---- vector store (Qdrant) --------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=engram_incidents

# ---- embeddings (local, open-source — NO API KEY NEEDED) --------------------
# Default model emits 384-dim vectors. If you change the model, set EMBEDDING_DIM
# to match (the embedder also reports the true dimension at startup).
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ---- reasoning LLM (the ONLY paid dependency; provider-swappable) -----------
# LLM_PROVIDER: anthropic | openai | gemini
# LLM_MODEL examples:  anthropic -> claude-3-5-sonnet-latest
#                      openai    -> gpt-4o
#                      gemini    -> gemini-1.5-pro
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-latest
LLM_API_KEY=REPLACE_WITH_YOUR_LLM_API_KEY

# ---- tenant bootstrap -------------------------------------------------------
# Seeds one tenant + API key on `engram migrate`/startup so the API and
# dashboard work immediately. Pick any opaque string for the key.
ENGRAM_BOOTSTRAP_API_KEY=REPLACE_WITH_A_RANDOM_API_KEY
ENGRAM_BOOTSTRAP_NETWORK_ID=acme-core-network

# ---- device capture (Netmiko SSH) -------------------------------------------
# Credentials used by `engram capture` to log into devices. For the Containerlab
# FRR demo the default is admin/admin (see seed_runbook.md).
DEVICE_SSH_USERNAME=admin
DEVICE_SSH_PASSWORD=REPLACE_WITH_DEVICE_PASSWORD

# ---- retrieval weights (documented; tune freely) ----------------------------
# final_score = W_VECTOR * vector_score + W_STRUCTURED * structured_score
RETRIEVAL_W_VECTOR=0.6
RETRIEVAL_W_STRUCTURED=0.4
